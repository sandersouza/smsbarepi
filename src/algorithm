#ifndef SMSBARE_CIRCLE_SMSBARE_CXX_ALGORITHM_SHIM
#define SMSBARE_CIRCLE_SMSBARE_CXX_ALGORITHM_SHIM

namespace std
{
template <typename T>
inline const T &min(const T &a,const T &b)
{
    return a < b ? a : b;
}

template <typename T>
inline const T &max(const T &a,const T &b)
{
    return a > b ? a : b;
}
} /* namespace std */

#endif /* SMSBARE_CIRCLE_SMSBARE_CXX_ALGORITHM_SHIM */
